generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// CORE MULTI-TENANT
// ============================================

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  phone       String?
  email       String?
  address     String?
  city        String?
  state       String?
  rfc         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branches      Branch[]
  users         User[]
  modules       TenantModule[]
  subscription  Subscription?
  customers     Customer[]
  products      Product[]
  categories    Category[]
  repairs       Repair[]
  sales         Sale[]
  cashSessions  CashSession[]
  staff         Staff[]
  suppliers     Supplier[]
  purchases     Purchase[]
  invoices      Invoice[]
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  users        User[]
  inventory    Inventory[]
  repairs      Repair[]
  sales        Sale[]
  cashSessions CashSession[]
  staff        Staff[]
}

// ============================================
// M3 - USUARIOS Y AUTENTICACIÓN
// ============================================

model User {
  id           String    @id @default(cuid())
  tenantId     String
  branchId     String?
  email        String
  name         String
  avatarUrl    String?
  supabaseId   String    @unique
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  branch      Branch?      @relation(fields: [branchId], references: [id])
  role        UserRole?
  sales       Sale[]
  repairs     Repair[]
  cashSessions CashSession[]

  @@unique([tenantId, email])
}

// ============================================
// M4 - ROLES Y PERMISOS
// ============================================

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  userRoles   UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, name])
}

model Permission {
  id          String @id @default(cuid())
  module      String
  action      String
  description String?

  roles RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model UserRole {
  userId String @unique
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])
}

// ============================================
// M0 - MÓDULOS Y SUSCRIPCIONES
// ============================================

model Module {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  isCore      Boolean @default(false)

  tenants TenantModule[]
}

model TenantModule {
  tenantId  String
  moduleId  String
  isActive  Boolean  @default(true)
  enabledAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])

  @@id([tenantId, moduleId])
}

model Subscription {
  id        String             @id @default(cuid())
  tenantId  String             @unique
  plan      String
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime?
  price     Decimal            @db.Decimal(10, 2)
  currency  String             @default("MXN")

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

enum SubscriptionStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
}

// ============================================
// M6 - CATÁLOGO
// ============================================

model Category {
  id       String       @id @default(cuid())
  tenantId String
  name     String
  type     CategoryType
  parentId String?

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
}

enum CategoryType {
  PRODUCT
  PART
  SERVICE
}

model Product {
  id          String      @id @default(cuid())
  tenantId    String
  categoryId  String?
  sku         String?
  barcode     String?
  name        String
  description String?
  type        ProductType
  price       Decimal     @db.Decimal(10, 2)
  cost        Decimal?    @db.Decimal(10, 2)
  taxRate     Decimal     @default(16) @db.Decimal(5, 2)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  category      Category?       @relation(fields: [categoryId], references: [id])
  inventory     Inventory[]
  saleItems     SaleItem[]
  repairItems   RepairItem[]
  purchaseItems PurchaseItem[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
}

enum ProductType {
  PRODUCT
  PART
  SERVICE
}

// ============================================
// M12 - INVENTARIO
// ============================================

model Inventory {
  id        String   @id @default(cuid())
  productId String
  branchId  String
  stock     Int      @default(0)
  minStock  Int      @default(0)
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([productId, branchId])
}

// ============================================
// M7 - CLIENTES
// ============================================

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  phone     String?
  email     String?
  rfc       String?
  address   String?
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  sales    Sale[]
  repairs  Repair[]
  invoices Invoice[]
}

// ============================================
// M8 - PUNTO DE VENTA
// ============================================

model Sale {
  id             String      @id @default(cuid())
  tenantId       String
  branchId       String
  customerId     String?
  userId         String
  folio          String
  subtotal       Decimal     @db.Decimal(10, 2)
  tax            Decimal     @db.Decimal(10, 2)
  discount       Decimal     @default(0) @db.Decimal(10, 2)
  total          Decimal     @db.Decimal(10, 2)
  paymentMethod  PaymentMethod
  status         SaleStatus  @default(COMPLETED)
  notes          String?
  createdAt      DateTime    @default(now())

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  branch   Branch     @relation(fields: [branchId], references: [id])
  customer Customer?  @relation(fields: [customerId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  items    SaleItem[]
  invoice  Invoice?

  @@unique([tenantId, folio])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  REFUNDED
}

// ============================================
// M9 - TALLER Y REPARACIONES
// ============================================

model Repair {
  id            String       @id @default(cuid())
  tenantId      String
  branchId      String
  customerId    String
  userId        String
  folio         String
  deviceBrand   String
  deviceModel   String
  deviceSerial  String?
  issueDesc     String
  diagnosisDesc String?
  status        RepairStatus @default(RECEIVED)
  priority      Priority     @default(NORMAL)
  estimatedCost Decimal?     @db.Decimal(10, 2)
  finalCost     Decimal?     @db.Decimal(10, 2)
  receivedAt    DateTime     @default(now())
  estimatedAt   DateTime?
  deliveredAt   DateTime?
  publicToken   String       @unique @default(cuid())
  whatsappSent  Boolean      @default(false)
  notes         String?

  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  branch   Branch       @relation(fields: [branchId], references: [id])
  customer Customer     @relation(fields: [customerId], references: [id])
  user     User         @relation(fields: [userId], references: [id])
  items    RepairItem[]
  history  RepairHistory[]

  @@unique([tenantId, folio])
}

model RepairItem {
  id        String  @id @default(cuid())
  repairId  String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  repair  Repair  @relation(fields: [repairId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model RepairHistory {
  id        String       @id @default(cuid())
  repairId  String
  status    RepairStatus
  notes     String?
  createdAt DateTime     @default(now())

  repair Repair @relation(fields: [repairId], references: [id])
}

enum RepairStatus {
  RECEIVED
  DIAGNOSING
  WAITING_PARTS
  IN_REPAIR
  READY
  DELIVERED
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================
// M10 - CAJA
// ============================================

model CashSession {
  id           String          @id @default(cuid())
  tenantId     String
  branchId     String
  userId       String
  openingCash  Decimal         @db.Decimal(10, 2)
  closingCash  Decimal?        @db.Decimal(10, 2)
  expectedCash Decimal?        @db.Decimal(10, 2)
  difference   Decimal?        @db.Decimal(10, 2)
  status       CashSessionStatus @default(OPEN)
  openedAt     DateTime        @default(now())
  closedAt     DateTime?
  notes        String?

  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  branch       Branch          @relation(fields: [branchId], references: [id])
  user         User            @relation(fields: [userId], references: [id])
  movements    CashMovement[]
}

model CashMovement {
  id            String       @id @default(cuid())
  cashSessionId String
  type          MovementType
  amount        Decimal      @db.Decimal(10, 2)
  concept       String
  createdAt     DateTime     @default(now())

  cashSession CashSession @relation(fields: [cashSessionId], references: [id])
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum MovementType {
  INCOME
  EXPENSE
}

// ============================================
// M11 - PERSONAL
// ============================================

model Staff {
  id         String    @id @default(cuid())
  tenantId   String
  branchId   String
  name       String
  phone      String?
  email      String?
  position   String?
  baseSalary Decimal   @db.Decimal(10, 2)
  commission Decimal   @default(0) @db.Decimal(5, 2)
  hiredAt    DateTime  @default(now())
  isActive   Boolean   @default(true)

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  branch      Branch       @relation(fields: [branchId], references: [id])
  attendances Attendance[]
}

model Attendance {
  id        String    @id @default(cuid())
  staffId   String
  date      DateTime  @db.Date
  checkIn   DateTime?
  checkOut  DateTime?
  notes     String?

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
}

// ============================================
// M12 - PROVEEDORES Y COMPRAS
// ============================================

model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  phone     String?
  email     String?
  rfc       String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  purchases Purchase[]
}

model Purchase {
  id         String         @id @default(cuid())
  tenantId   String
  supplierId String
  folio      String
  total      Decimal        @db.Decimal(10, 2)
  status     PurchaseStatus @default(PENDING)
  notes      String?
  createdAt  DateTime       @default(now())

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  supplier Supplier       @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]

  @@unique([tenantId, folio])
}

model PurchaseItem {
  id         String  @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Int
  cost       Decimal @db.Decimal(10, 2)
  subtotal   Decimal @db.Decimal(10, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}

// ============================================
// M14 - FACTURACIÓN CFDI
// ============================================

model Invoice {
  id         String        @id @default(cuid())
  tenantId   String
  customerId String
  saleId     String?       @unique
  folio      String
  uuid       String?       @unique
  cfdiXml    String?
  cfdiPdf    String?
  status     InvoiceStatus @default(PENDING)
  total      Decimal       @db.Decimal(10, 2)
  createdAt  DateTime      @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  sale     Sale?    @relation(fields: [saleId], references: [id])

  @@unique([tenantId, folio])
}

enum InvoiceStatus {
  PENDING
  STAMPED
  CANCELLED
}